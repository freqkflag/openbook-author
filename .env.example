# OpenBook Author — environment variables (optional)
#
# Copy to .env.local for local overrides (never commit .env.local).
# Most configuration is in-app (AI keys, book data). Only Electron/dev
# tooling uses env vars today.

# Port for the Next.js server when running the Electron shell.
# Used by: npm run electron:dev, electron/main.cjs
# Default: 3847
OPENBOOK_PORT=3847

# AI provider API keys are NOT configured here.
# Set them in the editor: AI panel → Settings (stored in browser localStorage).

# Homelab Forgejo CI (optional — set real values in .env.local only, never commit tokens)
# FORGEJO_URL=http://192.168.12.115:3000
# FORGEJO_TOKEN=
# FORGEJO_OWNER=king
# FORGEJO_REPO=openbook-author
# FORGEJO_RUNNER_TOKEN=
